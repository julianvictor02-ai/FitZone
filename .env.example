# Supabase — Projekt-URL und anon-Key (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres-Connection-String für Drizzle (Dashboard → Project Settings → Database).
# Für Serverless/Vercel die Transaction-Pooler-URL (Port 6543) verwenden.
DATABASE_URL=

# Secret für den Warteliste-Cron-Endpoint (GET /api/cron/warteliste).
# Aufruf mit Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Kopiere diese Datei nach .env.local und trage die echten Werte ein.
# .env.local wird NICHT eingecheckt.
